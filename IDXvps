      echo -e "${CYAN}Running Real VPS (Any Location)...${RESET}"
      bash <(curl -fsSL https://raw.githubusercontent.com/pterodactylService/vps/refs/heads/main/nokvm.sh)
      ;;

    4)
      echo -e "${RED}Exiting...${RESET}"
      exit 0
      ;;

    *)
      echo -e "${RED}Invalid choice!${RESET}"
      sleep 1
      ;;

  esac

  echo ""
  read -p "Press Enter to return menu..."
