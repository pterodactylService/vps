#!/usr/bin/env python3

import os
import random
import string
import time

def display_banner():
    print(r"""
    ###########################################
    #                                         #
    #           ShadowCraftMC - 24/7          #
    #                                         #
    #                                         #
    ###########################################
    """)

def generate_random_string(length=100):
    return ''.join(random.choices(string.ascii_letters + string.digits, k=length))

def create_edit_delete_file():
    folder_name = "24_7_logs"
    if not os.path.exists(folder_name):
        os.makedirs(folder_name)

    print(f"Starting 24/7 process for ShadowCraftMC...")

    while True:
        try:
            file_name = os.path.join(folder_name, f"{generate_random_string(8)}.txt")

            # Create
            with open(file_name, "w") as file:
                for _ in range(random.randint(10, 50)):
                    file.write(generate_random_string(100) + "\n")
            print(f"[{time.strftime('%H:%M:%S')}] Created: {file_name}")

            time.sleep(5) # I made it a little longer so the server wouldn't be overloaded.

            # Edit
            with open(file_name, "a") as file:
                file.write("\n--- Edited by ShadowCraftMC ---\n")
                file.write(generate_random_string(100))
            print(f"[{time.strftime('%H:%M:%S')}] Edited: {file_name}")

            time.sleep(3)

            # Delete
            os.remove(file_name)
            print(f"[{time.strftime('%H:%M:%S')}] Deleted: {file_name}")

            time.sleep(2)

        except Exception as e:
            print(f"Error: {e}")
            time.sleep(10)

if __name__ == "__main__":
    display_banner()
    create_edit_delete_file()
